{
  "name": "peekabu-game-systems",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$path": "src/ReplicatedStorage",
      "Packages": {
        "$path": "Packages"
      },
      "DevPackages": {
        "$path": "DevPackages"
      }
    },
    "ServerScriptService": {
      "$path": "src/ServerScriptService",
      "ServerPackages": {
        "$path": "ServerPackages"
      }
    },
    "ServerStorage": {
      "$path": "src/ServerStorage"
    },
    "StarterPlayer": {
      "StarterCharacterScripts": {
        "$path": "src/StarterPlayer/StarterCharacterScripts"
      },
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      },
      "$path": "src/Lighting"
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    },
    "Workspace": {
      "$path": "src/Workspace"
    }
  }
}